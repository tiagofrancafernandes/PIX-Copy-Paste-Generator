{
    "name": "pix-copy-and-paste-generator",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "dev:client": "vite",
        "dev:server": "ts-node-dev --project server/tsconfig.json --respawn --transpile-only server/index.ts",
        "build": "vue-tsc --noEmit && vite build",
        "preview": "vite preview"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.19.2",
        "pinia": "^2.1.7",
        "qrcode-generator": "^1.4.4",
        "vite": "8.1.3",
        "vue": "^3.4.21",
        "vue-router": "^4.3.0",
        "vue3-toastify": "^0.2.9"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.24",
        "@vitejs/plugin-vue": "^5.0.4",
        "autoprefixer": "^10.4.18",
        "concurrently": "^8.2.2",
        "postcss": "^8.4.35",
        "prettier": "^3.2.5",
        "tailwindcss": "^3.4.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3",
        "vite-plugin-vue-devtools": "8.1.5",
        "vue-tsc": "^2.0.6"
    },
    "packageManager": "pnpm@10.20.0"
}
